GOOGLE_API_KEY="your_google_api_key_here"
# Initial admin password (seeded on first run). If empty, a random one is generated and logged once.
ADMIN_PASSWORD=""
# Comma-separated CORS origins. Empty defaults to localhost:8000.
ALLOWED_ORIGINS=""
# Zalo Bot token from https://bot.zapps.me (used in the API URL path).
ZALO_BOT_TOKEN=""
# Secret you set via setWebhook; Zalo sends it back in the X-Bot-Api-Secret-Token header.
ZALO_BOT_SECRET_TOKEN=""
