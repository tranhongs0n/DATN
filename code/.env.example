GOOGLE_API_KEY="your_google_api_key_here"
ZALO_ACCESS_TOKEN="your_zalo_access_token_here"
# Zalo OA app secret — used to verify webhook signatures. Leave empty to disable in dev.
ZALO_APP_SECRET=""
# Initial admin password (seeded on first run). If empty, a random one is generated and logged once.
ADMIN_PASSWORD=""
# Comma-separated CORS origins. Empty defaults to localhost:8000.
ALLOWED_ORIGINS=""
